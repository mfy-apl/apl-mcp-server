# Server
PORT=5005

# Database (MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# Authentication
MCP_API_KEY=           # Master API key for MCP/A2A access
JWT_SECRET=            # Hex-encoded HMAC secret for OAuth JWT tokens
SYSTEM_API_KEY=        # API key for internal system endpoints

# London Tech Dispatch API
LONDON_TECH_API_URL=https://api.london-tech.com/api/v1
GIA_ACCOUNT_ID=        # Your London Tech account ID
GIA_CHANNEL_ID=        # Your London Tech channel ID
GIA_USER_ID=           # Your London Tech user ID
GIA_AUTH_TOKEN=        # London Tech API auth token

# Google Maps (for distance calculations)
GOOGLE_MAPS_API_KEY=

# FlightStats (for flight validation)
FLIGHTSTATS_APP_ID=
FLIGHTSTATS_APP_KEY=

# LLM for chat (optional)
LLM_PROVIDER=gemini    # "gemini" or "claude"
GEMINI_API_KEY=

# Stripe (optional, for partner online payments)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# OAuth (for Google/Gemini Enterprise)
GOOGLE_CLIENT_ID=

# Partner server URL (optional)
PARTNERS_BASE_URL=
